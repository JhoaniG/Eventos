		{
			"name": "Generar 10 Usuarios (Runner)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Generar edad aleatoria entre 18 y 60",
							"pm.collectionVariables.set(\"randomEdad\", Math.floor(Math.random() * 42) + 18);",
							"// Generar cedula aleatoria para evitar duplicados",
							"pm.collectionVariables.set(\"randomCedula\", Math.floor(Math.random() * 89999999) + 10000000 + \"\");"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Lógica para repetir la petición 10 veces",
							"var count = pm.collectionVariables.get(\"loop_counter\");",
							"if (!count) count = 0;",
							"count = parseInt(count) + 1;",
							"pm.collectionVariables.set(\"loop_counter\", count);",
							"",
							"if (count < 10) {",
							"    // Instrucción para repetirse a sí mismo",
							"    postman.setNextRequest(\"Generar 10 Usuarios (Runner)\");",
							"} else {",
							"    // Limpiar variable y detener ejecución",
							"    pm.collectionVariables.unset(\"loop_counter\");",
							"    postman.setNextRequest(null);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"nombre\": \"{{$randomFirstName}}\",\n  \"apellido\": \"{{$randomLastName}}\",\n  \"cedula\": \"{{randomCedula}}\",\n  \"edad\": {{randomEdad}}\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8080/api/usuarios",
